# Base URL of your backend API (e.g. Zo Computer). All requests from the
# HTTP adapters in src/backend/adapters/http go to `${VITE_API_BASE_URL}${path}`.
# Leave empty to call same-origin relative paths.
VITE_API_BASE_URL=https://api.example.com

# Public URL this app is deployed at. Used only to build the "submit your
# vehicle" link inside the admin dashboard's shareable WhatsApp post.
VITE_PUBLIC_APP_URL=https://autoace.example.com
